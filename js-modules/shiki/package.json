{
    "name": "shiki",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "fmt": "pnpm run \"/^fmt:.*/\"",
        "fmt:oxfmt": "oxfmt \"**/*.{json,jsonc,yaml,md,css,js,ts,html,vue,less}\"",
        "generate-config": "node ./scripts/generate-config.js",
        "prebuild": "pnpm run generate-config",
        "preview": "vite preview"
    },
    "dependencies": {
        "shiki": "^4.0.2"
    },
    "devDependencies": {
        "js-yaml": "^4.1.1",
        "oxfmt": "^0.46.0",
        "vite": "8.0.10"
    },
    "engines": {
        "node": ">=24",
        "pnpm": "^10.33.2"
    },
    "packageManager": "pnpm@10.33.2"
}
