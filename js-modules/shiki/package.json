{
    "name": "shiki",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "fmt": "pnpm run \"/^fmt:.*/\"",
        "fmt:oxfmt": "oxfmt --threads 2 \"**/*.{json,jsonc,yaml,md,css,js,ts,html,vue,less}\"",
        "generate-config": "node ./scripts/generate-config.js",
        "prebuild": "pnpm run generate-config",
        "preview": "vite preview"
    },
    "dependencies": {
        "shiki": "^4.2.0"
    },
    "devDependencies": {
        "oxfmt": "^0.59.0",
        "vite": "8.1.5",
        "yaml": "^2.9.0"
    },
    "engines": {
        "node": ">=24",
        "pnpm": "^11.13.0"
    },
    "packageManager": "pnpm@11.13.0"
}
