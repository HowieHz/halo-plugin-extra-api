{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "run-p build:type-check \"build:build-only {@}\" --",
        "build:build-only": "rsbuild build",
        "build:type-check": "vue-tsc --build",
        "dev": "pnpm run \"/^watch:.*/\"",
        "fmt": "pnpm run \"/^fmt:.*/\"",
        "fmt:oxfmt": "oxfmt --threads 2 \"**/*.{json,jsonc,yaml,md,css,js,ts,html,vue,less}\"",
        "lint": "run-s lint:*",
        "lint:eslint": "eslint . --fix",
        "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
        "prepare": "cd .. && husky ui/.husky",
        "test": "pnpm run \"/^test:.*/\"",
        "test:unit": "vitest --passWithNoTests",
        "watch:rsbuild": "rsbuild build --watch --env-mode=development"
    },
    "dependencies": {
        "@halo-dev/api-client": "^2.24.0",
        "@halo-dev/components": "^2.24.0",
        "@halo-dev/ui-shared": "^2.24.0",
        "axios": "^1.16.1",
        "canvas-confetti": "^1.9.4",
        "husky": "^9.1.7",
        "vue": "^3.5.34"
    },
    "devDependencies": {
        "@halo-dev/ui-plugin-bundler-kit": "^2.24.0",
        "@iconify/json": "^2.2.473",
        "@rsbuild/core": "^2.0.6",
        "@rsbuild/plugin-sass": "^1.5.2",
        "@tsconfig/node24": "^24.0.1",
        "@types/canvas-confetti": "^1.9.0",
        "@types/jsdom": "^28.0.3",
        "@types/node": "^25.8.0",
        "@vitest/eslint-plugin": "^1.6.17",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/test-utils": "^2.4.10",
        "@vue/tsconfig": "^0.9.1",
        "eslint": "^10.4.0",
        "eslint-plugin-oxlint": "^1.65.0",
        "eslint-plugin-vue": "~10.9.1",
        "husky": "^8.0.0",
        "jsdom": "^29.1.1",
        "npm-run-all2": "^8.0.4",
        "oxfmt": "^0.50.0",
        "oxlint": "^1.65.0",
        "sass": "^1.99.0",
        "typescript": "~6.0.3",
        "unplugin-icons": "^23.0.1",
        "vitest": "^4.1.6",
        "vue-tsc": "^3.2.9"
    },
    "engines": {
        "node": ">=24",
        "pnpm": "^11.1.2"
    },
    "packageManager": "pnpm@11.1.2"
}
