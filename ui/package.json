{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "pnpm run \"/^watch:.*/\"",
        "watch:rsbuild": "rsbuild build --watch --env-mode=development",
        "build": "run-p build:type-check \"build:build-only {@}\" --",
        "build:type-check": "vue-tsc --build",
        "build:build-only": "rsbuild build",
        "lint": "run-s lint:*",
        "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
        "lint:eslint": "eslint . --fix",
        "format": "pnpm run \"/^format:.*/\"",
        "format:prettier": "prettier --write src/",
        "test": "pnpm run \"/^test:.*/\"",
        "test:unit": "vitest --passWithNoTests",
        "prepare": "cd .. && husky ui/.husky"
    },
    "prettier": {
        "printWidth": 100,
        "semi": false,
        "singleQuote": true,
        "tabWidth": 2
    },
    "dependencies": {
        "@halo-dev/api-client": "^2.23.0",
        "@halo-dev/components": "^2.23.0",
        "@halo-dev/ui-shared": "^2.23.0",
        "axios": "^1.14.0",
        "canvas-confetti": "^1.9.4",
        "husky": "^9.1.7",
        "vue": "^3.5.31"
    },
    "devDependencies": {
        "@halo-dev/ui-plugin-bundler-kit": "^2.23.0",
        "@iconify/json": "^2.2.456",
        "@rsbuild/core": "^1.7.5",
        "@rsbuild/plugin-sass": "^1.5.1",
        "@tsconfig/node20": "^20.1.9",
        "@types/canvas-confetti": "^1.9.0",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^25.5.0",
        "@vitest/eslint-plugin": "^1.6.13",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.9.1",
        "eslint": "^10.1.0",
        "eslint-plugin-oxlint": "^1.57.0",
        "eslint-plugin-vue": "~10.8.0",
        "husky": "^8.0.0",
        "jsdom": "^29.0.1",
        "npm-run-all2": "^8.0.4",
        "oxlint": "^1.57.0",
        "prettier": "^3.8.1",
        "sass": "^1.98.0",
        "typescript": "~5.9.3",
        "unplugin-icons": "^23.0.1",
        "vitest": "^4.1.2",
        "vue-tsc": "^3.2.6"
    },
    "engines": {
        "node": ">=25",
        "pnpm": "^10.33.0"
    },
    "packageManager": "pnpm@10.33.0"
}
