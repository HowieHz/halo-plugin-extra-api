{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "run-p build:type-check \"build:build-only {@}\" --",
        "build:build-only": "rsbuild build",
        "build:type-check": "vue-tsc --build",
        "dev": "pnpm run \"/^watch:.*/\"",
        "fmt": "pnpm run \"/^fmt:.*/\"",
        "fmt:oxfmt": "oxfmt --threads 2 \"**/*.{json,jsonc,yaml,md,css,js,ts,html,vue,less}\"",
        "lint": "run-s lint:*",
        "lint:eslint": "eslint . --fix",
        "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
        "prepare": "cd .. && husky ui/.husky",
        "test": "pnpm run \"/^test:.*/\"",
        "test:unit": "vitest --passWithNoTests",
        "watch:rsbuild": "rsbuild build --watch --env-mode=development"
    },
    "dependencies": {
        "@halo-dev/api-client": "^2.25.2",
        "@halo-dev/components": "^2.25.2",
        "@halo-dev/ui-shared": "^2.25.2",
        "axios": "^1.18.1",
        "canvas-confetti": "^1.9.4",
        "husky": "^9.1.7",
        "vue": "^3.5.39",
        "vue-router": "^5.2.0"
    },
    "devDependencies": {
        "@halo-dev/ui-plugin-bundler-kit": "^2.25.2",
        "@iconify/json": "^2.2.500",
        "@rsbuild/core": "^2.1.6",
        "@rsbuild/plugin-sass": "^2.0.1",
        "@rsbuild/plugin-vue": "^2.0.1",
        "@tsconfig/node24": "^24.0.4",
        "@types/canvas-confetti": "^1.9.0",
        "@types/jsdom": "^28.0.3",
        "@types/node": "^26.1.1",
        "@vitest/eslint-plugin": "^1.6.23",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.9.0",
        "@vue/test-utils": "^2.4.11",
        "@vue/tsconfig": "^0.9.1",
        "eslint": "^10.7.0",
        "eslint-plugin-oxlint": "^1.73.0",
        "eslint-plugin-vue": "~10.9.2",
        "husky": "^8.0.3",
        "jsdom": "^29.1.1",
        "npm-run-all2": "^9.0.2",
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0",
        "sass": "^1.101.0",
        "typescript": "~7.0.2",
        "unplugin-icons": "^23.0.1",
        "vitest": "^4.1.10",
        "vue-tsc": "^3.3.7"
    },
    "engines": {
        "node": ">=24",
        "pnpm": "^11.13.0"
    },
    "packageManager": "pnpm@11.13.0"
}
